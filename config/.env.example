# X Configuration
X_EMAIL=your_x_email@example.com
X_USERNAME=your_x_username
X_PASSWORD=your_x_password

# Social Searcher Configuration
SOCIAL_SEARCHER_EMAIL=your_social_searcher_email@example.com
SOCIAL_SEARCHER_PASSWORD=your_social_searcher_password

# Mention Configuration
MENTION_EMAIL=your_mention_email@example.com
MENTION_PASSWORD=your_mention_password

# Email Notification Configuration
EMAIL_NOTIFICATION_ENABLED=true
EMAIL_RECIPIENTS=ProjectAlphaOPC@gmail.com
NOTIFY_ON_COLLECTION=false
NOTIFY_ON_PROCESSING=false
NOTIFY_ON_ANALYSIS=true

# Email notification settings
EMAIL_NOTIFICATION_ENABLED=true
EMAIL_RECIPIENTS=ProjectAlphaOPC@gmail.com
NOTIFY_ON_COLLECTION=false
NOTIFY_ON_PROCESSING=false
NOTIFY_ON_ANALYSIS=true

# Individual to monitor
# Configure these to change the target for all collectors
TARGET_INDIVIDUAL="Bola Ahmed Tinubu" 
QUERY_VARIATIONS=["Bola Tinubu", "Bola Ahmed Tinubu", "President Tinubu", "Tinubu", "Nigeria President", "Nigerian President", "Nigeria", "Asiwaju"]

# Alternative examples:
# For Qatar Emir:
# TARGET_INDIVIDUAL="Sheikh Tamim bin Hamad Al Thani"
# QUERY_VARIATIONS=["Sheikh Tamim", "Emir of Qatar", "Qatar Emir", "Tamim Al Thani", "Qatar", "Doha", "Gulf"]
#
# For Modi:
# TARGET_INDIVIDUAL="Narendra Modi"
# QUERY_VARIATIONS=["Modi", "PM Modi", "India", "BJP", "Prime Minister Modi", "Indian PM"]

# Database Configuration
DATABASE_URL=postgresql://user:password@host:port/dbname

# Analysis Worker (queue-first with NOTIFY and poll fallback)
ANALYSIS_USE_QUEUE=true
ANALYSIS_POLL_INTERVAL=2.0
ANALYSIS_BATCH_SIZE=50
ANALYSIS_MAX_WORKERS=25
ANALYSIS_MAX_RETRIES=3
ANALYSIS_USE_NOTIFY=true
ANALYSIS_POLL_LOOKBACK_HOURS=168